{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArduPilot Labeled Diagnostic Case",
  "type": "object",
  "required": [
    "case_id",
    "log_reference",
    "vehicle_type",
    "issue_label",
    "analysis_window",
    "evidence_summary"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "log_reference": {
      "type": "string",
      "description": "Reference to the source log or internal dataset identifier"
    },
    "vehicle_type": {
      "type": "string"
    },
    "issue_label": {
      "type": "string",
      "description": "Primary expert-supported issue label"
    },
    "alternative_labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "analysis_window": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string" },
        "end": { "type": "string" }
      }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "evidence_summary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "review_notes": {
      "type": "string"
    },
    "source_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
